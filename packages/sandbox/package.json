{
  "name": "@larkup/sandbox",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./docker-runner": {
      "types": "./dist/docker-runner.d.ts",
      "import": "./dist/docker-runner.js",
      "default": "./dist/docker-runner.js"
    },
    "./sandbox-manager": {
      "types": "./dist/sandbox-manager.d.ts",
      "import": "./dist/sandbox-manager.js",
      "default": "./dist/sandbox-manager.js"
    }
  },
  "scripts": {
    "build": "tsc --outDir dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "dockerode": "^4.0.7"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.38",
    "typescript": "5.7.3"
  }
}
