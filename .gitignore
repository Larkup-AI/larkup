# ═══════════════════════════════════════════════════
# Larkup Monorepo — .gitignore
# ═══════════════════════════════════════════════════

# ── Environment & Secrets ─────────────────────────
.env
.env.*
!.env.example
.snowflake/

# ── Dependencies & Build ─────────────────────────
node_modules/
dist/
build/
.next/
.turbo/
.vercel/

# ── OS & IDE ─────────────────────────────────────
.DS_Store
**/.DS_Store
.vscode/
*.swp
*.swo

# ── Python ───────────────────────────────────────
__pycache__/
*.egg-info/
venv/
.venv/
.pytest_cache/

# ── Larkup Local State ──────────────────────────
.larkup/
lancedb/
proxies.txt

# ── Test Artifacts ───────────────────────────────
playwright-report/
e2e/playwright-report/
e2e/test-results/
apps/web/webui.log

# ── App-Specific ─────────────────────────────────
apps/web/demo
apps/local-chat-connection-larkup

# ── Desktop Binaries ─────────────────────────────
apps/desktop/src-tauri/binaries/
apps/desktop/src-tauri/target/

# ── Sensitive / Internal ─────────────────────────
npm-login.sh
hpi-connect.txt
keys.txt
TODO.md

# ── Archived / Generated ────────────────────────
archive/
dummy/
apps/api