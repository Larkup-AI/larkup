{
  "name": "@larkup/sdk",
  "version": "0.1.20",
  "publishConfig": {
    "access": "public"
  },
  "description": "JavaScript/TypeScript SDK for Larkup servers",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "require": "./dist/react.cjs",
      "import": "./dist/react.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/react.tsx --format cjs,esm --dts --external react",
    "dev": "tsup src/index.ts src/react.tsx --format cjs,esm --dts --watch --external react",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^1.6.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}
