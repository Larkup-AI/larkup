{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Larkup",
  "version": "0.1.0",
  "identifier": "de.larkup.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Larkup",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "resources": {
      "../../../apps/web/.next/standalone": "server"
    },
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v2Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/larkup-server"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2MjY1NkM0ODhGM0JBMDkKUldRSnV2T0l4RlltMW04bmFGWGxzR1JOcXA3RGlHM2VlSFg0SUN0Mk1maGh2VTY2VDlVNnlSTlAK",
      "endpoints": [
        "https://larkup.de/api/tauri-update/{{target}}/{{current_version}}"
      ]
    }
  }
}
