{
  "name": "@larkup/e2e",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:web": "playwright test tests/web-ui/",
    "test:api": "playwright test tests/api/",
    "test:sdk": "playwright test tests/sdk/",
    "test:cli": "playwright test tests/cli/",
    "test:install": "playwright test tests/installation/",
    "test:docker": "docker compose -f ../docker/docker-compose.e2e.yml up --build --abort-on-container-exit && docker compose -f ../docker/docker-compose.e2e.yml down",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@larkup/sdk": "workspace:*",
    "@playwright/test": "^1.61.1",
    "dotenv": "^17.4.2",
    "typescript": "7.0.2"
  }
}
